# Copy this file to android/keystore.properties and fill in the REAL values.
# android/keystore.properties is gitignored — never commit it or the .keystore.
#
# RELEASE_STORE_FILE is resolved relative to the android/app/ module directory.
RELEASE_STORE_FILE=release.keystore
RELEASE_STORE_PASSWORD=changeme
RELEASE_KEY_ALIAS=remotelink
RELEASE_KEY_PASSWORD=changeme
