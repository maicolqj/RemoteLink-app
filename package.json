{
  "name": "remotelink",
  "version": "0.2.0",
  "private": true,
  "scripts": {
    "android": "cross-env NODE_ENV=development react-native run-android",
    "ios": "cross-env NODE_ENV=development react-native run-ios",
    "lint": "eslint .",
    "start": "cross-env NODE_ENV=development react-native start",
    "start:fresh": "cross-env NODE_ENV=development react-native start --reset-cache",
    "android:prod": "cross-env NODE_ENV=production react-native run-android --mode=release",
    "ios:prod": "cross-env NODE_ENV=production react-native run-ios --configuration Release",
    "build:staging": "cd android && set \"BUILD_ENV=staging\" && .\\gradlew.bat assembleStaging -PreactNativeArchitectures=armeabi-v7a,arm64-v8a,x86,x86_64",
    "build:apk": "cd android && set \"NODE_ENV=production\" && set \"BUILD_ENV=production\" && set \"BUILD_DIST=apk\" && .\\gradlew.bat assembleRelease -PreactNativeArchitectures=armeabi-v7a,arm64-v8a,x86,x86_64",
    "build:aab": "cd android && set \"NODE_ENV=production\" && set \"BUILD_ENV=production\" && set \"BUILD_DIST=aab\" && .\\gradlew.bat bundleRelease -PreactNativeArchitectures=armeabi-v7a,arm64-v8a,x86,x86_64",
    "test": "jest",
    "postinstall": "patch-package",
    "codegen": "graphql-codegen --config codegen.ts",
    "codegen:watch": "graphql-codegen --config codegen.ts --watch",
    "schema:pull": "node scripts/pull-schema.js",
    "sync-manifest": "node scripts/sync-manifest.js"
  },
  "dependencies": {
    "@apollo/client": "^4.2.3",
    "@notifee/react-native": "^9.1.8",
    "@react-native-async-storage/async-storage": "^3.1.1",
    "@react-native-firebase/app": "^24.0.0",
    "@react-native-firebase/messaging": "^24.0.0",
    "@react-navigation/bottom-tabs": "^7.16.1",
    "@react-navigation/elements": "^2.9.18",
    "@react-navigation/native": "^7.2.4",
    "@react-navigation/native-stack": "^7.15.1",
    "graphql": "^16.14.2",
    "graphql-ws": "^6.0.8",
    "react": "19.2.3",
    "react-native": "0.85.3",
    "react-native-dotenv": "^3.4.11",
    "react-native-keychain": "^10.0.0",
    "react-native-qrcode-svg": "^6.3.21",
    "react-native-safe-area-context": "^5.5.2",
    "react-native-screens": "^4.25.2",
    "react-native-share": "^12.3.1",
    "react-native-svg": "^15.15.5",
    "react-native-vector-icons": "^10.3.0",
    "rxjs": "^7.3.0",
    "socket.io-client": "^4.8.3",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@babel/preset-env": "^7.25.3",
    "@babel/runtime": "^7.25.0",
    "@graphql-codegen/cli": "^5.0.7",
    "@graphql-codegen/client-preset": "^4.8.3",
    "@react-native-community/cli": "20.1.0",
    "@react-native-community/cli-platform-android": "20.1.0",
    "@react-native-community/cli-platform-ios": "20.1.0",
    "@react-native/babel-preset": "0.85.3",
    "@react-native/eslint-config": "0.85.3",
    "@react-native/jest-preset": "0.85.3",
    "@react-native/metro-config": "0.85.3",
    "@react-native/typescript-config": "0.85.3",
    "@types/jest": "^29.5.13",
    "@types/react": "^19.2.0",
    "@types/react-native-vector-icons": "^6.4.18",
    "@types/react-test-renderer": "^19.1.0",
    "babel-plugin-transform-remove-console": "^6.9.4",
    "cross-env": "^10.1.0",
    "eslint": "^8.19.0",
    "jest": "^29.6.3",
    "patch-package": "^8.0.1",
    "prettier": "2.8.8",
    "react-test-renderer": "19.2.3",
    "typescript": "^5.8.3"
  },
  "engines": {
    "node": ">= 22.11.0"
  }
}
